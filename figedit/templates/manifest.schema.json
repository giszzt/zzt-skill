{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Editable SVG Reconstruction Manifest",
  "type": "object",
  "required": [
    "project",
    "source_image",
    "canvas",
    "classification",
    "assets",
    "elements"
  ],
  "properties": {
    "project": {
      "type": "string"
    },
    "source_image": {
      "type": "string"
    },
    "canvas": {
      "type": "object",
      "required": [
        "width",
        "height"
      ],
      "properties": {
        "width": {
          "type": "number"
        },
        "height": {
          "type": "number"
        },
        "background": {
          "type": "string"
        }
      }
    },
    "classification": {
      "type": "object",
      "required": [
        "layout_topology",
        "complexity",
        "style_type",
        "reconstruction_mode"
      ],
      "properties": {
        "layout_topology": {
          "type": "string"
        },
        "complexity": {
          "type": "string"
        },
        "style_type": {
          "type": "string"
        },
        "reconstruction_mode": {
          "type": "string"
        },
        "reconstruction_intent": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "panels": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "x",
          "y",
          "w",
          "h"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          },
          "w": {
            "type": "number"
          },
          "h": {
            "type": "number"
          },
          "strategy": {
            "type": "string"
          }
        }
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "file",
          "x",
          "y",
          "w",
          "h"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "file": {
            "type": "string"
          },
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          },
          "w": {
            "type": "number"
          },
          "h": {
            "type": "number"
          },
          "pad": {
            "type": "number"
          },
          "source_region": {
            "type": "object",
            "properties": {
              "x": {
                "type": "number"
              },
              "y": {
                "type": "number"
              },
              "w": {
                "type": "number"
              },
              "h": {
                "type": "number"
              }
            }
          },
          "panel_id": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "decision": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "asset_fidelity": {
            "type": "string"
          },
          "decision_reason": {
            "type": "string"
          },
          "background_handling": {
            "type": "string"
          },
          "crop_status": {
            "type": "string"
          },
          "crop_confidence": {
            "type": "number"
          },
          "edge_check": {
            "type": "object"
          },
          "padding_applied": {
            "type": "number"
          },
          "neighbor_risk": {
            "type": "string"
          },
          "text_policy": {
            "type": "string"
          },
          "edge_policy": {
            "type": "string"
          },
          "verification_notes": {
            "type": "string"
          }
        }
      }
    },
    "elements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "panel_id": {
            "type": "string"
          },
          "class": {
            "type": "string"
          },
          "subtype": {
            "type": "string"
          },
          "decision": {
            "type": "string"
          },
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          },
          "w": {
            "type": "number"
          },
          "h": {
            "type": "number"
          },
          "rx": {
            "type": "number"
          },
          "ry": {
            "type": "number"
          },
          "r": {
            "type": "number"
          },
          "points": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "latex": {
            "type": "string"
          },
          "math_format": {
            "type": "string"
          },
          "math_backend": {
            "type": "string"
          },
          "formula_policy": {
            "type": "string"
          },
          "formula_decision_reason": {
            "type": "string"
          },
          "text_anchor": {
            "type": "string"
          },
          "dominant_baseline": {
            "type": "string"
          },
          "lines": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "font_size": {
            "type": "number"
          },
          "font_weight": {
            "type": "string"
          },
          "font_family": {
            "type": "string"
          },
          "fill": {
            "type": "string"
          },
          "stroke": {
            "type": "string"
          },
          "stroke_width": {
            "type": "number"
          },
          "dasharray": {
            "type": "string"
          },
          "opacity": {
            "type": "number"
          },
          "asset_id": {
            "type": "string"
          },
          "source_id": {
            "type": "string"
          },
          "source_bbox": {
            "type": "object",
            "properties": {
              "x": {
                "type": "number"
              },
              "y": {
                "type": "number"
              },
              "w": {
                "type": "number"
              },
              "h": {
                "type": "number"
              }
            }
          },
          "confidence": {
            "type": "number"
          },
          "detector": {
            "type": "string"
          },
          "style_source": {
            "type": "string"
          },
          "review_status": {
            "type": "string"
          },
          "href": {
            "type": "string"
          },
          "d": {
            "type": "string"
          },
          "x1": {
            "type": "number"
          },
          "y1": {
            "type": "number"
          },
          "x2": {
            "type": "number"
          },
          "y2": {
            "type": "number"
          },
          "arrow_start": {
            "type": "boolean"
          },
          "arrow_end": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          },
          "decision_reason": {
            "type": "string"
          },
          "asset_fidelity": {
            "type": "string"
          },
          "background_handling": {
            "type": "string"
          }
        }
      }
    },
    "style_tokens": {
      "type": "object"
    },
    "diagnostics": {
      "type": "object"
    },
    "quality_gates": {
      "type": "object"
    }
  }
}
